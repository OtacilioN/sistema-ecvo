# ───────────── Banco de dados (PostgreSQL na Neon) ─────────────
# String de conexão "pooled" (usada pela aplicação em runtime).
DATABASE_URL="postgresql://USUARIO:SENHA@HOST-pooler.REGION.aws.neon.tech/ecvo?sslmode=require"
# String de conexão "direta" (usada pelo Prisma para migrations).
DIRECT_URL="postgresql://USUARIO:SENHA@HOST.REGION.aws.neon.tech/ecvo?sslmode=require"

# ───────────── Sessão / Autenticação ─────────────
# Gere com: openssl rand -base64 32
SESSION_SECRET="troque-por-uma-chave-secreta-de-32-bytes"

# ───────────── Tarefas agendadas ─────────────
# Usado pelo Vercel Cron para gerar aulas futuras de turmas recorrentes.
# Gere com: openssl rand -base64 32
CRON_SECRET="troque-por-uma-chave-secreta-para-cron"

# ───────────── App ─────────────
# Usado em e-mails/links; em produção, a URL pública do app.
NEXT_PUBLIC_APP_URL="http://localhost:3000"
